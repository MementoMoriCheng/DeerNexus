  "description": "DeerNexus Platform Overview — Gateway availability/latency/traffic/errors, Run create/status/duration, SSE, PostgreSQL pool, Sandbox. observability-and-slo.md §8.1 (PR-063).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Gateway availability (§6.1, SLO 99.5%/30d)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1))",
          "legendFormat": "availability",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "yellow", "value": 0.99}, {"color": "green", "value": 0.995}]}}}
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Request rate by status class",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum by (status_class) (rate(http_requests_total[5m]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Request latency P95 (s) by route",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route_template) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route_template}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Runs created / status (§6.2 success rate)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(runs_created_total[5m]))",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "expr": "sum by (run_status) (rate(runs_status_total[5m]))",
          "legendFormat": "{{run_status}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Run duration P95 (s) by terminal status",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, terminal_status) (rate(run_duration_seconds_bucket[5m])))",
          "legendFormat": "{{terminal_status}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Run admission P95 (s) (§6.3, SLO <3s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(run_admission_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Active SSE connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "active_sse_connections",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "SSE first business event P95 (s) (§6.4, SLO <5s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sse_first_business_event_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Rate-limit rejections (auth login lockout)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "targets": [
        {
          "expr": "sum by (reason) (rate(rate_limit_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "DB pool in-use / size",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "db_pool_in_use",
          "legendFormat": "in use",
          "refId": "A"
        },
        {
          "expr": "db_pool_size",
          "legendFormat": "size",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "DB query latency P95 (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "DB transaction failures",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "targets": [
        {
          "expr": "sum by (error_class) (rate(db_transaction_failure_total[5m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Sandbox active / acquire P95 (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "sandbox_active",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sandbox_acquire_duration_seconds_bucket[5m])))",
          "legendFormat": "acquire P95",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "title": "Reconcile backlog + outcome rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "run_reconcile_backlog",
          "legendFormat": "backlog",
          "refId": "A"
        },
        {
          "expr": "sum by (outcome) (rate(run_reconcile_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "B"
        }
      ]
    }
  ],
